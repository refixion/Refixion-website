# Database Configuration (Supabase PostgreSQL)
# Use Supabase's "Transaction" pooler connection string (port 6543) for serverless
# deployments (e.g. Vercel) — it's backed by PgBouncer and handles many short-lived
# connections far better than a direct connection. Find it in:
# Supabase Dashboard -> Project Settings -> Database -> Connection string -> Transaction.
# Either postgres:// or postgresql:// prefixes are accepted; the app normalizes them.
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:your-password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin Credentials (change on first deployment)
ADMIN_EMAIL=admin@refixion.com
ADMIN_PASSWORD=change-me-in-production

# CORS Configuration (frontend URL)
CORS_ORIGINS=http://localhost:3000,https://refixion.vercel.app

# Email Notifications
INTERNAL_NOTIFICATION_EMAIL=notifications@refixion.com
